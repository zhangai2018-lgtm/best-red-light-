---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return paginate(getSortedPosts(posts), { pageSize: SITE.postPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const totalPosts = page.total ?? page.data.length;
const currentPage = page.currentPage ?? 1;
---

<Layout title={`Reviews & Buying Guides | ${SITE.title}`}>
  <Header />

  <main class="posts-page">
    <section class="posts-hero">
      <div class="hero-glow hero-glow-one"></div>
      <div class="hero-glow hero-glow-two"></div>

      <div class="hero-inner">
        <div class="eyebrow">
          <span class="eyebrow-dot"></span>
          Red Light Therapy Research & Reviews
        </div>

        <h1>Latest Red Light Panel Reviews</h1>

        <p class="hero-desc">
          Independent buying guides, product comparisons, and practical reviews to help you choose the right red light therapy panel for full body use.
        </p>

        <div class="hero-stats">
          <div class="stat-card">
            <strong>{totalPosts}</strong>
            <span>Total Articles</span>
          </div>
          <div class="stat-card">
            <strong>{currentPage}</strong>
            <span>Current Page</span>
          </div>
          <div class="stat-card">
            <strong>{page.lastPage}</strong>
            <span>Total Pages</span>
          </div>
        </div>
      </div>
    </section>

    <section class="posts-content">
      <div class="section-head">
        <div>
          <p class="section-label">All Articles</p>
          <h2>Reviews, Comparisons & Buying Guides</h2>
        </div>
        <p>
          Browse our latest editorial guides on red light therapy panels, wavelengths, full body coverage, and home wellness devices.
        </p>
      </div>

      <ul class="posts-list">
        {page.data.map(data => <Card {...data} />)}
      </ul>
    </section>

    <div class="pagination-wrap">
      <Pagination {page} />
    </div>
  </main>

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>

<style>
  .posts-page {
    background:
      radial-gradient(circle at 18% 8%, rgba(232, 112, 58, 0.18), transparent 32%),
      radial-gradient(circle at 82% 18%, rgba(196, 70, 29, 0.14), transparent 30%),
      linear-gradient(180deg, #fdf6ee 0%, #fffaf5 42%, #fdf6ee 100%);
    min-height: 100vh;
    color: #2a1810;
  }

  .posts-hero {
    position: relative;
    overflow: hidden;
    padding: 96px 24px 76px;
    border-bottom: 1px solid rgba(196, 110, 60, 0.12);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1040px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-glow {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
    filter: blur(2px);
  }

  .hero-glow-one {
    width: 460px;
    height: 460px;
    left: -160px;
    top: -180px;
    background: radial-gradient(circle, rgba(255, 184, 138, 0.55), transparent 68%);
  }

  .hero-glow-two {
    width: 540px;
    height: 540px;
    right: -180px;
    bottom: -260px;
    background: radial-gradient(circle, rgba(196, 70, 29, 0.22), transparent 70%);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 9px 18px;
    margin-bottom: 24px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(196, 70, 29, 0.16);
    color: #c4461d;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    box-shadow: 0 10px 30px rgba(196, 70, 29, 0.06);
  }

  .eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #c4461d;
    box-shadow: 0 0 0 6px rgba(196, 70, 29, 0.12);
  }

  .posts-hero h1 {
    max-width: 880px;
    margin: 0 auto 22px;
    color: #2a1810;
    font-size: clamp(42px, 7vw, 82px);
    font-weight: 900;
    line-height: 1.02;
    letter-spacing: -2.5px;
  }

  .hero-desc {
    max-width: 690px;
    margin: 0 auto;
    color: #6b4537;
    font-size: 18px;
    line-height: 1.75;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    max-width: 680px;
    margin: 46px auto 0;
  }

  .stat-card {
    padding: 22px 20px;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(196, 110, 60, 0.14);
    box-shadow: 0 14px 36px rgba(196, 70, 29, 0.08);
    backdrop-filter: blur(12px);
  }

  .stat-card strong {
    display: block;
    color: #c4461d;
    font-family: Georgia, serif;
    font-size: 34px;
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-card span {
    color: #8c6852;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .posts-content {
    max-width: 1120px;
    margin: 0 auto;
    padding: 76px 40px 28px;
  }

  .section-head {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    align-items: end;
    margin-bottom: 34px;
  }

  .section-label {
    margin: 0 0 10px;
    color: #c4461d;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .section-head h2 {
    margin: 0;
    color: #2a1810;
    font-size: clamp(30px, 4vw, 46px);
    font-weight: 850;
    line-height: 1.12;
    letter-spacing: -1.2px;
  }

  .section-head p {
    margin: 0;
    color: #6b4537;
    font-size: 15px;
    line-height: 1.75;
  }

  .posts-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .pagination-wrap {
    max-width: 1120px;
    margin: 10px auto 0;
    padding: 0 40px 72px;
  }

  .posts-list :global(li),
  .posts-list :global(article),
  .posts-list :global(.card) {
    border-radius: 24px;
  }

  .posts-list :global(li) {
    list-style: none;
  }

  .posts-list :global(a) {
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }

  .posts-list :global(a:hover) {
    transform: translateY(-3px);
  }

  @media (max-width: 800px) {
    .posts-hero {
      padding: 76px 20px 58px;
    }

    .hero-stats {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin-top: 34px;
    }

    .posts-content {
      padding: 56px 20px 20px;
    }

    .section-head {
      grid-template-columns: 1fr;
      gap: 16px;
      margin-bottom: 28px;
    }

    .pagination-wrap {
      padding: 0 20px 56px;
    }
  }

  @media (max-width: 520px) {
    .posts-hero h1 {
      letter-spacing: -1.4px;
    }

    .hero-desc {
      font-size: 16px;
    }

    .eyebrow {
      font-size: 10px;
      letter-spacing: 1.3px;
    }

    .stat-card {
      padding: 20px 18px;
    }
  }
</style>
