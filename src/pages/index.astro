  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      background: #fdf6ee;
      color: #2a1810;
      overflow-x: hidden;
      line-height: 1.65;
    }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; display: block; }
    h1, h2, h3 { font-family: 'Fraunces', serif; }

    /* ========= Affiliate Disclosure Bar ========= */
    .disclosure-bar {
      background: #2a1810;
      color: #fdf6ee;
      text-align: center;
      padding: 9px 20px;
      font-size: 12px;
      letter-spacing: 0.3px;
    }
    .disclosure-bar a { text-decoration: underline; opacity: 0.85; }

    /* ========= Navigation ========= */
    nav {
      position: sticky; top: 0; z-index: 999;
      padding: 16px 32px;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(253, 246, 238, 0.92);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(196, 110, 60, 0.12);
    }

    /* ========= Logo (放大优化) ========= */
    .logo {
      font-family: 'Fraunces', serif;
      display: flex; align-items: center; gap: 12px;
      letter-spacing: -0.5px;
    }
    .logo-mark {
      position: relative;
      width: 40px; height: 40px;
      border-radius: 50%;
      background: radial-gradient(circle at 32% 30%,
        #ffd9b8 0%,
        #ff9656 30%,
        #c4461d 70%,
        #6b1f08 100%);
      box-shadow:
        0 0 0 2px rgba(196, 70, 29, 0.08),
        0 0 26px rgba(232, 112, 58, 0.55),
        inset 0 -3px 10px rgba(107, 31, 8, 0.4);
      flex-shrink: 0;
    }
    .logo-mark::after {
      content: '';
      position: absolute;
      top: 7px; left: 10px;
      width: 13px; height: 9px;
      background: rgba(255, 240, 220, 0.6);
      border-radius: 50%;
      filter: blur(2px);
    }
    .logo-text {
      display: flex; flex-direction: column;
      line-height: 1;
    }
    .logo-text .top {
      color: #2a1810;
      font-size: 24px; font-weight: 800;
    }
    .logo-text .bot {
      color: #c4461d;
      font-size: 11px; font-weight: 600;
      font-family: 'Inter', sans-serif;
      letter-spacing: 2.5px;
      margin-top: 4px;
      text-transform: uppercase;
    }

    .nav-links { display: flex; gap: 32px; align-items: center; }
    .nav-links a { font-size: 14px; color: #6b4537; font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: #c4461d; }
    .btn-nav {
      font-size: 13px; font-weight: 700; color: #fff;
      background: linear-gradient(135deg, #e8703a, #c4461d);
      padding: 10px 22px; border-radius: 100px;
      box-shadow: 0 4px 14px rgba(196, 70, 29, 0.3);
    }

    /* ========= HERO ========= */
    .hero {
      position: relative;
      min-height: 88vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center;
      padding: 90px 24px 80px;
      background:
        radial-gradient(ellipse at 20% 10%, rgba(255, 184, 138, 0.45) 0%, transparent 50%),
        radial-gradient(ellipse at 85% 90%, rgba(232, 112, 58, 0.30) 0%, transparent 50%),
        linear-gradient(180deg, #fdf6ee 0%, #fce8d4 100%);
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: 50%; left: 50%; transform: translate(-50%, -50%);
      width: 700px; height: 700px;
      background: radial-gradient(circle, rgba(255, 140, 80, 0.18) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }
    .hero-badge {
      position: relative;
      display: inline-flex; align-items: center; gap: 9px;
      font-size: 12px; font-weight: 700; color: #c4461d;
      text-transform: uppercase; letter-spacing: 2px;
      margin-bottom: 28px;
      background: rgba(255, 255, 255, 0.7);
      padding: 8px 18px; border-radius: 100px;
      border: 1px solid rgba(196, 70, 29, 0.2);
    }
    .badge-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: #c4461d;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(196, 70, 29, 0.6); }
      50% { box-shadow: 0 0 0 8px rgba(196, 70, 29, 0); }
    }
    .hero h1 {
      position: relative;
      font-size: clamp(38px, 6.5vw, 76px);
      font-weight: 900; line-height: 1.05;
      letter-spacing: -2px;
      margin-bottom: 24px; max-width: 980px;
      color: #2a1810;
    }
    .hero h1 em {
      font-style: italic;
      background: linear-gradient(135deg, #e8703a, #c4461d 60%, #8b2c10);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      position: relative;
      font-size: 19px; color: #6b4537;
      max-width: 640px; line-height: 1.7;
      margin-bottom: 14px;
    }
    .hero-proof {
      position: relative;
      font-size: 13px; color: #8c6852;
      margin-bottom: 38px; font-weight: 500;
    }
    .hero-proof strong { color: #2a1810; font-weight: 700; }
    .hero-btns {
      position: relative;
      display: flex; gap: 14px; flex-wrap: wrap;
      justify-content: center; margin-bottom: 56px;
    }
    .btn-primary {
      font-size: 16px; font-weight: 700; color: #fff;
      background: linear-gradient(135deg, #e8703a, #c4461d);
      padding: 17px 42px; border-radius: 100px;
      box-shadow: 0 10px 28px rgba(196, 70, 29, 0.35);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 36px rgba(196, 70, 29, 0.45);
    }
    .btn-secondary {
      font-size: 16px; font-weight: 600; color: #2a1810;
      background: rgba(255, 255, 255, 0.7);
      border: 1.5px solid rgba(196, 70, 29, 0.25);
      padding: 17px 42px; border-radius: 100px;
      transition: all 0.2s;
    }
    .btn-secondary:hover {
      border-color: #c4461d; color: #c4461d;
      background: #fff;
    }
    .trust {
      position: relative;
      display: flex; gap: 32px; flex-wrap: wrap;
      justify-content: center;
      padding: 22px 36px;
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(10px);
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.6);
      box-shadow: 0 4px 24px rgba(196, 70, 29, 0.06);
    }
    .trust-item { font-size: 13px; color: #6b4537; font-weight: 500; }
    .trust-item strong { color: #2a1810; font-weight: 700; }

    /* ========= Sections ========= */
    .section { padding: 100px 48px; max-width: 1200px; margin: 0 auto; }
    .section-label {
      font-size: 12px; font-weight: 700; color: #c4461d;
      text-transform: uppercase; letter-spacing: 2.5px;
      margin-bottom: 14px;
    }
    .section-title {
      font-family: 'Fraunces', serif;
      font-size: clamp(30px, 4.2vw, 48px);
      font-weight: 800; letter-spacing: -1px;
      color: #2a1810; margin-bottom: 18px;
      line-height: 1.15;
    }
    .section-desc {
      font-size: 17px; color: #6b4537;
      line-height: 1.75; max-width: 540px;
    }

    /* ========= Why It Matters Grid ========= */
    .why-section {
      background: linear-gradient(180deg, #fdf6ee 0%, #fce8d4 100%);
      padding: 100px 48px;
    }
    .why-inner { max-width: 1200px; margin: 0 auto; }
    .why-header { text-align: center; margin-bottom: 56px; }
    .why-header .section-desc { margin: 0 auto; }
    .why-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .why-card {
      background: #fff;
      border-radius: 24px;
      padding: 36px 32px;
      border: 1px solid rgba(196, 110, 60, 0.1);
      transition: all 0.25s;
    }
    .why-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(196, 70, 29, 0.12);
      border-color: rgba(196, 110, 60, 0.3);
    }
    .why-icon {
      width: 56px; height: 56px;
      border-radius: 16px;
      background: linear-gradient(135deg, #ffb88a, #e8703a);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 22px;
      font-size: 26px;
      box-shadow: 0 8px 20px rgba(232, 112, 58, 0.3);
    }
    .why-card h3 {
      font-size: 21px; font-weight: 700;
      color: #2a1810; margin-bottom: 10px;
      letter-spacing: -0.3px;
    }
    .why-card p {
      font-size: 15px; color: #6b4537;
      line-height: 1.7;
    }

    /* ========= Top Picks ========= */
    .picks-section {
      padding: 100px 48px;
      max-width: 1280px; margin: 0 auto;
    }
    .picks-header {
      text-align: center; margin-bottom: 56px;
      max-width: 700px; margin-left: auto; margin-right: auto;
    }
    .picks-header .section-desc { margin: 0 auto; }
    .picks-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }
    .pick-card {
      background: #fff;
      border-radius: 24px;
      overflow: hidden;
      border: 1px solid rgba(196, 110, 60, 0.12);
      transition: all 0.25s;
      display: flex; flex-direction: column;
      position: relative;
    }
    .pick-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 50px rgba(196, 70, 29, 0.15);
    }
    .pick-card.top {
      border: 2px solid #c4461d;
      box-shadow: 0 12px 32px rgba(196, 70, 29, 0.12);
    }
    .pick-thumb {
      height: 200px;
      background: linear-gradient(135deg, #fff5ec 0%, #ffe0c2 100%);
      display: flex; align-items: center; justify-content: center;
      position: relative;
    }
    .pick-rank {
      position: absolute; top: 14px; left: 14px;
      font-size: 11px; font-weight: 800; color: #fff;
      border-radius: 8px; padding: 5px 12px;
      letter-spacing: 0.5px;
    }
    .rank-1 { background: linear-gradient(135deg, #c4461d, #8b2c10); }
    .rank-2 { background: linear-gradient(135deg, #e8703a, #c4461d); }
    .rank-3 { background: linear-gradient(135deg, #d97706, #b45309); }
    .pick-icon {
      width: 110px; height: 130px;
      border-radius: 14px;
      box-shadow: 0 12px 30px rgba(196, 70, 29, 0.25);
      position: relative;
      display: grid; grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(5, 1fr);
      gap: 4px;
      padding: 10px;
      background: #1a0f08;
    }
    .pick-icon::before {
      content: ''; position: absolute; inset: 0;
      border-radius: 14px;
      box-shadow: 0 0 40px rgba(255, 140, 80, 0.4);
      pointer-events: none;
    }
    .pick-icon span {
      background: radial-gradient(circle, rgba(255, 200, 150, 0.95), rgba(255, 110, 50, 0.7));
      border-radius: 50%;
      box-shadow: 0 0 6px rgba(255, 140, 80, 0.7);
    }
    .pick-body {
      padding: 26px 26px 28px;
      flex: 1;
      display: flex; flex-direction: column;
    }
    .pick-badge {
      display: inline-block;
      font-size: 11px; font-weight: 700;
      padding: 4px 11px; border-radius: 8px;
      margin-bottom: 12px;
      align-self: flex-start;
      letter-spacing: 0.3px;
    }
    .badge-1 { background: #fef2ec; color: #c4461d; }
    .badge-2 { background: #fef6ed; color: #d97706; }
    .badge-3 { background: #fffaf0; color: #b45309; }
    .pick-name {
      font-family: 'Fraunces', serif;
      font-size: 22px; font-weight: 700;
      color: #2a1810; margin-bottom: 6px;
      letter-spacing: -0.4px;
    }
    .pick-tag {
      font-size: 13px; color: #8c6852;
      margin-bottom: 16px;
    }

    /* ========= 编辑评分(替代 Amazon star ratings)========= */
    .editor-score {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 16px;
      background: linear-gradient(135deg, #fdf6ee, #fce8d4);
      border-radius: 12px;
      margin-bottom: 18px;
      border: 1px solid rgba(196, 110, 60, 0.12);
    }
    .editor-score-num {
      font-family: 'Fraunces', serif;
      font-size: 28px; font-weight: 800;
      color: #c4461d;
      line-height: 1;
      letter-spacing: -0.5px;
    }
    .editor-score-num small {
      font-size: 14px; color: #8c6852;
      font-weight: 600;
    }
    .editor-score-meta {
      font-size: 11px; color: #8c6852;
      line-height: 1.4;
    }
    .editor-score-meta strong {
      display: block;
      color: #2a1810; font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.3px;
      text-transform: uppercase;
      margin-bottom: 2px;
    }

    .pick-features {
      list-style: none;
      margin-bottom: 18px;
      padding-bottom: 18px;
      border-bottom: 1px solid #f3e6d6;
    }
    .pick-features li {
      font-size: 13px; color: #6b4537;
      padding: 4px 0 4px 22px;
      position: relative;
      line-height: 1.5;
    }
    .pick-features li::before {
      content: '✓';
      position: absolute; left: 0;
      color: #c4461d; font-weight: 700;
    }
    .pick-cta-note {
      font-size: 12px; color: #a08470;
      margin-bottom: 14px;
      text-align: center;
    }
    .pick-btn {
      display: block; text-align: center;
      font-size: 14px; font-weight: 700;
      padding: 14px; border-radius: 12px;
      transition: all 0.2s;
      margin-top: auto;
    }
    .pick-btn.primary {
      background: linear-gradient(135deg, #e8703a, #c4461d);
      color: #fff;
      box-shadow: 0 6px 18px rgba(196, 70, 29, 0.3);
    }
    .pick-btn.primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 24px rgba(196, 70, 29, 0.4);
    }
    .pick-btn-secondary {
      display: block; text-align: center;
      font-size: 12px; color: #8c6852;
      padding: 8px;
      margin-top: 8px;
      transition: color 0.2s;
    }
    .pick-btn-secondary:hover { color: #c4461d; }

    /* ========= Buying Guide ========= */
    .guide-section {
      background: #2a1810;
      padding: 100px 48px;
      margin: 0;
      position: relative;
      overflow: hidden;
    }
    .guide-section::before {
      content: '';
      position: absolute;
      top: -200px; right: -200px;
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(232, 112, 58, 0.15), transparent 70%);
      border-radius: 50%;
    }
    .guide-section::after {
      content: '';
      position: absolute;
      bottom: -200px; left: -200px;
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(196, 70, 29, 0.12), transparent 70%);
      border-radius: 50%;
    }
    .guide-inner {
      max-width: 1100px; margin: 0 auto;
      position: relative; z-index: 1;
    }
    .guide-section .section-label { color: #ffb88a; }
    .guide-section .section-title { color: #fdf6ee; }
    .guide-section .section-desc { color: #c9b8a8; margin-bottom: 56px; }
    .guide-grid {
      display: grid; grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    .guide-card {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 184, 138, 0.15);
      border-radius: 20px;
      padding: 32px;
      transition: all 0.2s;
    }
    .guide-card:hover {
      border-color: rgba(255, 184, 138, 0.4);
      background: rgba(255, 255, 255, 0.06);
    }
    .guide-num {
      font-family: 'Fraunces', serif;
      font-size: 14px; font-weight: 700;
      color: #ffb88a; margin-bottom: 10px;
      letter-spacing: 1.5px;
    }
    .guide-card h3 {
      font-size: 20px; font-weight: 700;
      color: #fdf6ee; margin-bottom: 12px;
      letter-spacing: -0.3px;
    }
    .guide-card p {
      font-size: 14px; color: #c9b8a8;
      line-height: 1.7;
    }

    /* ========= Comparison Table ========= */
    .compare-section { padding: 100px 48px; max-width: 1200px; margin: 0 auto; }
    .compare-header { text-align: center; margin-bottom: 48px; }
    .compare-header .section-desc { margin: 0 auto; }
    .compare-wrap {
      background: #fff; border-radius: 24px;
      overflow: hidden; overflow-x: auto;
      border: 1px solid rgba(196, 110, 60, 0.12);
      box-shadow: 0 8px 28px rgba(196, 70, 29, 0.06);
    }
    table.compare {
      width: 100%; border-collapse: collapse;
      min-width: 720px;
    }
    table.compare th {
      background: #fdf6ee;
      padding: 18px 20px;
      text-align: left;
      font-size: 13px; font-weight: 700;
      color: #2a1810;
      letter-spacing: 0.3px;
      border-bottom: 2px solid #f3e6d6;
    }
    table.compare th:first-child {
      font-family: 'Fraunces', serif;
      font-size: 14px;
    }
    table.compare td {
      padding: 18px 20px;
      font-size: 14px; color: #6b4537;
      border-bottom: 1px solid #f3e6d6;
    }
    table.compare td:first-child {
      font-weight: 700; color: #2a1810;
    }
    table.compare tr:last-child td { border-bottom: none; }
    table.compare tr:hover td { background: #fdf6ee; }

    /* ========= FAQ ========= */
    .faq-section {
      padding: 100px 48px;
      max-width: 880px; margin: 0 auto;
    }
    .faq-header { text-align: center; margin-bottom: 48px; }
    .faq-item {
      background: #fff;
      padding: 30px 34px;
      border-radius: 20px;
      border: 1px solid rgba(196, 110, 60, 0.12);
      margin-bottom: 16px;
      transition: all 0.2s;
    }
    .faq-item:hover {
      border-color: rgba(196, 110, 60, 0.3);
      box-shadow: 0 8px 24px rgba(196, 70, 29, 0.06);
    }
    .faq-q {
      font-family: 'Fraunces', serif;
      font-size: 19px; font-weight: 700;
      color: #2a1810; margin-bottom: 12px;
      letter-spacing: -0.2px;
    }
    .faq-a {
      font-size: 15px; color: #6b4537;
      line-height: 1.75;
    }

    /* ========= CTA ========= */
    .cta-section {
      background: linear-gradient(135deg, #c4461d 0%, #8b2c10 100%);
      text-align: center;
      padding: 110px 24px;
      position: relative; overflow: hidden;
    }
    .cta-section::before {
      content: '';
      position: absolute;
