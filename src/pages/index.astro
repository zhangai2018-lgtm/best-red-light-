---
import { getCollection } from "astro:content";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";

const allPosts = await getCollection("blog", ({ data, id }) => {
  return !data.draft && !id.startsWith("examples/") && !id.startsWith("_releases/");
});
const recentPosts = getSortedPosts(allPosts).slice(0, 3);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Best Window Cleaning Robot 2026 — Expert Lab Reviews & Top Picks</title>
  <meta name="description" content="We tested 48+ robotic window cleaners in 2026. See our top picks for high-rise safety, frameless glass, and best value. Lab-verified, unbiased rankings."/>
  <meta property="og:type" content="website"/>
  <meta property="og:title" content="Best Window Cleaning Robot 2026 — Expert Lab Reviews"/>
  <meta property="og:description" content="We tested 48+ robotic window cleaners. Lab-verified rankings, zero sponsored results."/>
  <meta property="og:image" content="/images/og-cover.jpg"/>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "AeroGlass Reviews",
    "url": "https://yourdomain.com",
    "description": "Independent expert reviews of the best window cleaning robots"
  }
  </script>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the best window cleaning robot in 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Based on our lab tests, the AeroGlass Pro is the best window cleaning robot in 2026 for high-rise buildings, featuring 3000Pa suction and a 60-minute UPS backup battery."
        }
      },
      {
        "@type": "Question",
        "name": "Will the robot fall if the power goes out?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. The AeroGlass Pro has an internal UPS backup battery that maintains suction for 60 minutes during power outages, plus a physical safety tether rated at 150kg."
        }
      },
      {
        "@type": "Question",
        "name": "Can robotic window cleaners work on frameless glass?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The AeroGlass Pro uses dual-ring vacuum suction and laser edge detection to work safely on frameless glass, skylights, and glass railings."
        }
      }
    ]
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: #f0f4f8; color: #1e293b; overflow-x: hidden; line-height: 1.6; }
    a { text-decoration: none; }
    img { max-width: 100%; height: auto; display: block; }

    nav {
      position: fixed; top: 20px; left: 50%; transform: translateX(-50%);
      z-index: 9999; padding: 12px 32px;
      display: flex; align-items: center; gap: 40px;
      background: rgba(255,255,255,0.85); backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.4); border-radius: 100px;
      box-shadow: 0 8px 32px rgba(56,189,248,0.1);
    }
    .logo { font-size: 17px; font-weight: 800; color: #1e293b; }
    .nav-links { display: flex; gap: 24px; align-items: center; }
    .nav-links a { font-size: 14px; color: #64748b; font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: #1e293b; }
    .btn-nav { font-size: 13px; font-weight: 700; color: #fff; background: linear-gradient(135deg, #38bdf8, #818cf8); padding: 9px 22px; border-radius: 100px; }

    .hero {
      min-height: 100vh; display: flex; flex-direction: column;
      align-items: center; justify-content: center; text-align: center;
      padding: 130px 24px 80px;
      background: radial-gradient(circle at 50% 0%, #dbeafe 0%, #f0f4f8 55%);
    }
    .hero-badge { display: inline-flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 700; color: #6366f1; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 24px; background: rgba(99,102,241,0.08); padding: 6px 16px; border-radius: 100px; border: 1px solid rgba(99,102,241,0.15); }
    .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #6366f1; }
    .hero h1 { font-size: clamp(40px, 7vw, 82px); font-weight: 900; line-height: 1.0; letter-spacing: -3px; margin-bottom: 24px; max-width: 950px; background: linear-gradient(135deg, #0f172a 30%, #6366f1 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero-sub { font-size: 19px; color: #64748b; max-width: 560px; line-height: 1.75; margin-bottom: 16px; }
    .hero-proof { font-size: 13px; color: #94a3b8; margin-bottom: 40px; font-weight: 500; }
    .hero-proof strong { color: #64748b; }
    .hero-btns { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; margin-bottom: 56px; }
    .btn-primary { font-size: 16px; font-weight: 700; color: #fff; background: linear-gradient(135deg, #38bdf8, #6366f1); padding: 16px 40px; border-radius: 100px; box-shadow: 0 8px 32px rgba(99,102,241,0.35); transition: transform 0.2s; }
    .btn-primary:hover { transform: translateY(-2px); }
    .btn-secondary { font-size: 16px; font-weight: 600; color: #1e293b; border: 1.5px solid #cbd5e1; padding: 16px 40px; border-radius: 100px; transition: border-color 0.2s; }
    .btn-secondary:hover { border-color: #6366f1; color: #6366f1; }
    .trust { display: flex; gap: 32px; flex-wrap: wrap; justify-content: center; padding: 20px 32px; background: rgba(255,255,255,0.6); backdrop-filter: blur(10px); border-radius: 16px; border: 1px solid rgba(255,255,255,0.5); }
    .trust-item { font-size: 13px; color: #64748b; font-weight: 500; }
    .trust-item strong { color: #1e293b; font-weight: 700; }

    .section { padding: 96px 48px; max-width: 1200px; margin: 0 auto; }
    .section-label { font-size: 12px; font-weight: 700; color: #6366f1; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 12px; }
    .section-title { font-size: clamp(28px, 4vw, 44px); font-weight: 800; letter-spacing: -1.5px; color: #0f172a; margin-bottom: 16px; }
    .section-desc { font-size: 17px; color: #64748b; line-height: 1.75; max-width: 500px; }

    .feat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
    .feat-card { background: #fff; border-radius: 28px; padding: 48px; box-shadow: 0 4px 24px rgba(0,0,0,0.06); border: 1px solid rgba(226,232,240,0.8); }
    .feat-img-box { aspect-ratio: 4/3; border-radius: 24px; overflow: hidden; background: linear-gradient(135deg, #e0f2fe, #ede9fe); display: flex; align-items: center; justify-content: center; }
    .img-placeholder { display: flex; flex-direction: column; align-items: center; gap: 12px; color: #94a3b8; font-size: 14px; font-weight: 500; }
    .placeholder-icon { width: 72px; height: 72px; border-radius: 18px; background: linear-gradient(135deg, #38bdf8, #818cf8); }

    .specs-section { background: #0f172a; padding: 96px 48px; border-radius: 48px; margin: 0 24px; }
    .specs-section .section-title { color: #fff; }
    .specs-section .section-desc { color: #64748b; margin-bottom: 56px; }
    .specs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .spec-card { background: #1e293b; border-radius: 20px; padding: 28px; text-align: center; border: 1px solid rgba(255,255,255,0.06); transition: border-color 0.2s; }
    .spec-card:hover { border-color: rgba(99,102,241,0.4); }
    .spec-val { font-size: 34px; font-weight: 800; margin-bottom: 8px; background: linear-gradient(135deg, #38bdf8, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .spec-name { font-size: 13px; color: #64748b; font-weight: 500; }

    .picks-section { padding: 96px 48px; max-width: 1200px; margin: 0 auto; }
    .picks-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 48px; }
    .pick-card { background: #fff; border-radius: 20px; overflow: hidden; border: 1px solid #e2e8f0; transition: all 0.2s; }
    .pick-card:hover { border-color: #6366f1; transform: translateY(-3px); box-shadow: 0 12px 36px rgba(99,102,241,0.12); }
    .pick-card.top { border: 2px solid #0f172a; }
    .pick-thumb { height: 120px; background: linear-gradient(135deg, #f0f9ff, #ede9fe); display: flex; align-items: center; justify-content: center; position: relative; }
    .pick-rank { position: absolute; top: 12px; left: 12px; font-size: 11px; font-weight: 800; color: #fff; border-radius: 6px; padding: 3px 10px; }
    .rank-1 { background: #0f172a; }
    .rank-2 { background: #6366f1; }
    .rank-3 { background: #0ea5e9; }
    .pick-icon { width: 52px; height: 52px; border-radius: 12px; }
    .pick-body { padding: 18px 20px 22px; }
    .pick-badge { display: inline-block; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 6px; margin-bottom: 10px; }
    .badge-1 { background: #f0fdf4; color: #16a34a; }
    .badge-2 { background: #eff6ff; color: #2563eb; }
    .badge-3 { background: #fff7ed; color: #ea580c; }
    .pick-name { font-size: 16px; font-weight: 800; color: #0f172a; margin-bottom: 5px; }
    .pick-stars { font-size: 12px; color: #f59e0b; margin-bottom: 12px; }
    .pick-stars span { color: #0f172a; font-weight: 700; margin-left: 4px; }
    .pick-price { font-size: 22px; font-weight: 800; color: #0f172a; margin-bottom: 16px; }
    .pick-price small { font-size: 13px; font-weight: 400; color: #94a3b8; }
    .pick-btn { display: block; text-align: center; font-size: 13px; font-weight: 700; padding: 11px; border-radius: 10px; transition: all 0.2s; }
    .pick-btn.dark { background: #0f172a; color: #fff; }
    .pick-btn.dark:hover { background: #6366f1; }
    .pick-btn.outline { border: 1.5px solid #e2e8f0; color: #0f172a; }
    .pick-btn.outline:hover { border-color: #6366f1; color: #6366f1; }

    .faq-section { padding: 96px 48px; max-width: 860px; margin: 0 auto; }
    .faq-item { background: #fff; padding: 28px 32px; border-radius: 18px; border: 1px solid #e2e8f0; margin-bottom: 16px; }
    .faq-q { font-size: 17px; font-weight: 700; color: #0f172a; margin-bottom: 10px; }
    .faq-a { font-size: 15px; color: #64748b; line-height: 1.75; }

    .cta-section { background: #0f172a; text-align: center; padding: 100px 24px; position: relative; overflow: hidden; }
    .cta-section::before { content: ''; position: absolute; width: 700px; height: 700px; border-radius: 50%; background: radial-gradient(circle, rgba(99,102,241,0.2), transparent 65%); top: -300px; left: 50%; transform: translateX(-50%); }
    .cta-section h2 { font-size: clamp(32px, 5vw, 56px); font-weight: 900; color: #fff; letter-spacing: -2px; margin-bottom: 16px; position: relative; z-index: 1; }
    .cta-section p { font-size: 17px; color: #64748b; margin-bottom: 36px; position: relative; z-index: 1; }
    .btn-cta { display: inline-block; font-size: 17px; font-weight: 700; color: #0f172a; background: #fff; padding: 18px 52px; border-radius: 100px; position: relative; z-index: 1; transition: transform 0.2s; box-shadow: 0 8px 32px rgba(0,0,0,0.2); }
    .btn-cta:hover { transform: scale(1.03); }

    .posts-section { padding: 80px 48px; max-width: 1200px; margin: 0 auto; }
    .posts-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 40px; }
    .post-card { background: #fff; border-radius: 16px; padding: 24px; border: 1px solid #e8ecf0; transition: all 0.2s; display: block; }
    .post-card:hover { border-color: #6366f1; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(99,102,241,0.1); }
    .post-date { font-size: 12px; color: #94a3b8; font-weight: 500; margin-bottom: 8px; }
    .post-title { font-size: 16px; font-weight: 700; color: #0f172a; line-height: 1.4; margin-bottom: 8px; }
    .post-desc { font-size: 13px; color: #64748b; line-height: 1.6; }
    .posts-more { display: inline-flex; align-items: center; gap: 6px; margin-top: 32px; font-size: 14px; font-weight: 700; color: #6366f1; border: 1.5px solid #c7d2fe; border-radius: 10px; padding: 10px 24px; transition: background 0.2s; }
    .posts-more:hover { background: #eff6ff; }

    footer { background: #fff; padding: 40px 48px; border-top: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
    .footer-logo { font-size: 16px; font-weight: 800; color: #0f172a; }
    .footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
    .footer-links a { font-size: 13px; color: #94a3b8; transition: color 0.2s; }
    .footer-links a:hover { color: #6366f1; }

    @media (max-width: 768px) {
      nav { width: calc(100% - 32px); padding: 10px 18px; gap: 0; justify-content: space-between; }
      .nav-links { display: none; }
      .hero { padding: 110px 20px 60px; }
      .hero h1 { letter-spacing: -2px; }
      .feat-grid { grid-template-columns: 1fr; gap: 32px; }
      .section { padding: 64px 20px; }
      .specs-section { padding: 64px 20px; margin: 0 12px; border-radius: 28px; }
      .specs-grid { grid-template-columns: repeat(2, 1fr); }
      .picks-section { padding: 64px 20px; }
      .picks-grid { grid-template-columns: 1fr; }
      .faq-section { padding: 64px 20px; }
      .posts-section { padding: 48px 20px; }
      .posts-grid { grid-template-columns: 1fr; }
      footer { padding: 24px 20px; flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
